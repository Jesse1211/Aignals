#!/usr/bin/env bash
# aignals-hook — emit/maintain ~/.aignals/sessions/<id>.json from Claude Code hook payloads.
# Exit 0 on every path so Claude Code never breaks because of the indicator.

set -u

AIGNALS_HOME_DEFAULT="$HOME/.aignals"
AIGNALS_HOME="${AIGNALS_HOME:-$AIGNALS_HOME_DEFAULT}"
SESSIONS_DIR="$AIGNALS_HOME/sessions"

require_jq() {
  if ! command -v jq >/dev/null 2>&1; then
    echo "aignals-hook: jq not found. Install with: brew install jq" >&2
    exit 0
  fi
}

ensure_dirs() {
  mkdir -p "$SESSIONS_DIR" 2>/dev/null || true
  chmod 700 "$AIGNALS_HOME" 2>/dev/null || true
  chmod 700 "$SESSIONS_DIR" 2>/dev/null || true
}

atomic_write() {
  # atomic_write <path> < stdin
  local path="$1"
  local tmp="${path}.tmp.$$"
  cat > "$tmp"
  mv -f "$tmp" "$path"
}

# Millisecond-precision UTC ISO8601 so two events in the same wall-clock second
# still order correctly under the INV-8 reorder defense (a plain second-granular
# stamp would let a reordered same-second write win as a tie). Falls back to
# second granularity if perl/Time::HiRes is unavailable; ISO8601 still sorts
# lexically either way. The Swift side parses both forms.
now_iso() {
  perl -MTime::HiRes=time -e '
    my $t = time; my @g = gmtime($t);
    printf("%04d-%02d-%02dT%02d:%02d:%02d.%03dZ\n",
           $g[5]+1900, $g[4]+1, $g[3], $g[2], $g[1], $g[0], ($t-int($t))*1000);
  ' 2>/dev/null || date -u +"%Y-%m-%dT%H:%M:%S.000Z"
}

# INV-8 reorder defense. Hooks can fire/deliver out of order; the file must only
# ever advance in time. Given an incoming ISO8601 timestamp and an existing file,
# return 0 (apply the write) only if the incoming timestamp is >= the stored
# `updated_at`; return 1 (drop the write) when the stored timestamp is strictly
# newer. `date -u` is second-granular and ISO8601 sorts lexically, so a plain
# string compare is correct. A file with no/empty stored `updated_at` always
# applies.
timestamp_is_fresh() {
  # timestamp_is_fresh <incoming_iso> <file>
  local incoming="$1" file="$2"
  local stored
  stored="$(jq -r '.updated_at // empty' "$file" 2>/dev/null)"
  [ -z "$stored" ] && return 0
  # Drop only when stored is strictly newer than incoming.
  if [[ "$incoming" < "$stored" ]]; then
    return 1
  fi
  return 0
}

# create_session_file <file> <sid> <payload> <state> <ts>
# Write a fresh schema-v2 session file. Used by on-sessionstart and, per ADR-25 /
# INV-14 (adopt-on-event), by the UPDATE-class subcommands when their target file
# is absent — a session that was already running before hooks were installed gets
# adopted on its next event (SessionStart does NOT re-fire for it).
create_session_file() {
  local file="$1" sid="$2" payload="$3" state="$4" ts="$5"
  local cwd; cwd="$(echo "$payload" | jq -r '.cwd // empty')"
  local project; project="$(basename "${cwd:-$PWD}")"
  local pid; pid="$(echo "$payload" | jq -r '.pid // empty')"
  [ -z "$pid" ] && pid="${PPID:-0}"
  jq -n \
    --argjson schema_version 2 \
    --arg session_id "$sid" \
    --arg tool "claude-code" \
    --argjson pid "$pid" \
    --arg project_name "$project" \
    --arg cwd "${cwd:-$PWD}" \
    --arg state "$state" \
    --arg started_at "$ts" \
    --arg updated_at "$ts" \
    '{schema_version:$schema_version, session_id:$session_id, tool:$tool, pid:$pid, project_name:$project_name, cwd:$cwd, state:$state, started_at:$started_at, updated_at:$updated_at}' \
    | atomic_write "$file"
}

# --- subcommands ---
cmd_on_sessionstart() {
  require_jq; ensure_dirs
  local payload; payload="$(cat)"
  local sid; sid="$(echo "$payload" | jq -r '.session_id // empty')"
  [ -z "$sid" ] && exit 0
  local ts; ts="$(now_iso)"
  create_session_file "$SESSIONS_DIR/$sid.json" "$sid" "$payload" "waiting_input" "$ts"
}

# cmd_set_state <state> — set a session file's state + updated_at. If the file
# already exists this updates it (applying the INV-8 reorder guard and bumping
# schema_version to 2). If it is absent it is CREATED with the given state per
# ADR-25 / INV-14 (adopt-on-event).
cmd_set_state() {
  local state="$1"
  require_jq; ensure_dirs
  local payload; payload="$(cat)"
  local sid; sid="$(echo "$payload" | jq -r '.session_id // empty')"
  [ -z "$sid" ] && exit 0
  local file="$SESSIONS_DIR/$sid.json"
  local ts; ts="$(now_iso)"

  if [ ! -f "$file" ]; then
    create_session_file "$file" "$sid" "$payload" "$state" "$ts"
    exit 0
  fi

  timestamp_is_fresh "$ts" "$file" || exit 0

  jq --argjson schema_version 2 \
     --arg state "$state" \
     --arg updated_at "$ts" \
     '.schema_version = $schema_version | .state = $state | .updated_at = $updated_at' \
     "$file" | atomic_write "$file"
}

cmd_on_pretool() {
  require_jq; ensure_dirs
  local payload; payload="$(cat)"
  local sid; sid="$(echo "$payload" | jq -r '.session_id // empty')"
  [ -z "$sid" ] && exit 0
  local file="$SESSIONS_DIR/$sid.json"
  local ts; ts="$(now_iso)"

  # ADR-25 / INV-14 (adopt-on-event): a pre-existing session has no file yet, so
  # back-fill one with state=working before recording its current_action below.
  local created=0
  if [ ! -f "$file" ]; then
    create_session_file "$file" "$sid" "$payload" "working" "$ts"
    created=1
  fi

  # On an existing file honor the INV-8 reorder guard; a just-created file is
  # already at this exact timestamp, so skip the guard for it.
  if [ "$created" -eq 0 ]; then
    timestamp_is_fresh "$ts" "$file" || exit 0
  fi

  local tool_name; tool_name="$(echo "$payload" | jq -r '.tool_name // empty')"
  local target=""
  case "$tool_name" in
    Bash)
      target="$(echo "$payload" | jq -r '.tool_input.command // empty' | cut -c1-80)" ;;
    Edit|Write|MultiEdit|Read)
      target="$(echo "$payload" | jq -r '.tool_input.file_path // empty')" ;;
    Grep|Glob)
      target="$(echo "$payload" | jq -r '.tool_input.pattern // empty')" ;;
    WebFetch)
      target="$(echo "$payload" | jq -r '.tool_input.url // empty')" ;;
    WebSearch)
      target="$(echo "$payload" | jq -r '.tool_input.query // empty')" ;;
    *)
      target="" ;;
  esac

  jq --argjson schema_version 2 \
     --arg state "working" \
     --arg tool "$tool_name" \
     --arg target "$target" \
     --arg updated_at "$ts" \
     '.schema_version = $schema_version
      | .state = $state
      | .updated_at = $updated_at
      | .current_action = {tool:$tool, target:$target, updated_at:$updated_at}' \
     "$file" | atomic_write "$file"
}

cmd_remove() {
  ensure_dirs
  local payload; payload="$(cat 2>/dev/null || true)"
  local sid
  if command -v jq >/dev/null 2>&1; then
    sid="$(echo "$payload" | jq -r '.session_id // empty')"
  else
    sid=""
  fi
  [ -z "$sid" ] && exit 0
  rm -f "$SESSIONS_DIR/$sid.json" 2>/dev/null || true
}

case "${1:-}" in
  on-sessionstart)      cmd_on_sessionstart ;;
  on-prompt)            cmd_set_state "working" ;;
  on-pretool)           cmd_on_pretool ;;
  on-posttool)          cmd_set_state "working" ;;
  on-permission)        cmd_set_state "waiting_permission" ;;
  on-permission-denied) cmd_set_state "working" ;;
  on-idle)              cmd_set_state "waiting_input" ;;
  on-stop)              cmd_set_state "waiting_input" ;;
  on-sessionend)        cmd_remove ;;
  --help|-h|"")
    cat <<USAGE
usage: aignals-hook <subcommand>
Reads Claude Code hook payload from stdin.

subcommands:
  on-sessionstart       SessionStart      -> create file, state=waiting_input
  on-prompt             UserPromptSubmit  -> state=working
  on-pretool            PreToolUse        -> state=working + current_action
  on-posttool           PostToolUse       -> state=working
  on-permission         Notification(permission_prompt) -> state=waiting_permission
  on-permission-denied  PermissionDenied  -> state=working
  on-idle               Notification(idle_prompt)       -> state=waiting_input
  on-stop               Stop              -> state=waiting_input (file kept)
  on-sessionend         SessionEnd        -> delete file
USAGE
    ;;
  *)
    echo "aignals-hook: unknown subcommand '$1'" >&2
    exit 0
    ;;
esac
